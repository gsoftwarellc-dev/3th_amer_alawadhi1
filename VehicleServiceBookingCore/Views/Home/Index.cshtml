@{
    ViewData["Title"] = "Home";
}

<section class="hero" aria-label="Welcome banner">
    <div class="hero-text">
        <p class="hero-eyebrow">Trusted Auto Care</p>
        <h1>Reliable Vehicle Maintenance, Made Simple</h1>
        <p>AutoCare Service Center helps you register your vehicle, book maintenance
           appointments, and track service history &mdash; all in one place.</p>
        <div class="hero-actions">
            <a class="btn" asp-controller="Customers" asp-action="Index">Get Started &rarr;</a>
            <a class="btn btn-secondary" asp-controller="Services" asp-action="Index">View Services</a>
        </div>
    </div>
    <div class="hero-image">
        <img src="https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?auto=format&fit=crop&w=900&q=80"
             alt="Close-up of a car engine bay during a maintenance inspection" width="900" height="600" loading="eager" />
    </div>
</section>

<section aria-label="Why choose us">
    <h2>Why Choose Us</h2>
    <div class="card-grid">
        <div class="card">
            <h3>Certified Mechanics</h3>
            <p>Our team of certified mechanics inspects and services every vehicle
               with care and precision.</p>
        </div>
        <div class="card">
            <h3>Easy Online Booking</h3>
            <p>Register your vehicle and book a maintenance slot in minutes through
               our simple booking form.</p>
        </div>
        <div class="card">
            <h3>Full Service History</h3>
            <p>Track every booking and status update for each of your vehicles from
               your customer profile.</p>
        </div>
    </div>
</section>

<section aria-label="How it works">
    <h2>How It Works</h2>
    <p class="subtitle">Follow these four steps in order to book your first service.</p>
    <div class="steps-guide">
        <a class="step-card" asp-controller="Customers" asp-action="Index">
            <span class="step-number">1</span>
            <h3>Register as a Customer</h3>
            <p>Create your customer profile with your name, email, and phone number.</p>
            <span class="step-cta">Start here &rarr;</span>
        </a>
        <span class="step-arrow" aria-hidden="true">&rarr;</span>
        <a class="step-card" asp-controller="Vehicles" asp-action="Index">
            <span class="step-number">2</span>
            <h3>Register Your Vehicle</h3>
            <p>Add your vehicle's plate number, brand, model, and year under your profile.</p>
            <span class="step-cta">Then this &rarr;</span>
        </a>
        <span class="step-arrow" aria-hidden="true">&rarr;</span>
        <a class="step-card" asp-controller="Bookings" asp-action="Index">
            <span class="step-number">3</span>
            <h3>Book a Service</h3>
            <p>Pick your vehicle, choose a service type, and select a date for your appointment.</p>
            <span class="step-cta">Then this &rarr;</span>
        </a>
        <span class="step-arrow" aria-hidden="true">&rarr;</span>
        <a class="step-card" asp-controller="ServiceHistory" asp-action="Index">
            <span class="step-number">4</span>
            <h3>Track Your Service</h3>
            <p>Check booking status, search past visits, and view your full service history.</p>
            <span class="step-cta">Finally &rarr;</span>
        </a>
    </div>
</section>
